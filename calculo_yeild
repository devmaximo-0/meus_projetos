import json
import os

allowed_lines = [
    'Be1', 'Be2', 'Be3', 'Be4', 'Be5', 'Be6', 'Be7', 'Be8',
    'Be9', 'Be10', 'Be11', 'Be12', 'Be13', 'Be14', 'Be15', 'Be16'
]

diretorio = 'minha_pasta'
nome_arquivo = 'resultado.json'
caminho_completo = os.path.join(diretorio, nome_arquivo)

os.makedirs(diretorio, exist_ok=True)

registros = []
if os.path.exists(caminho_completo):
    try:
        with open(caminho_completo, 'r', encoding='utf-8') as arquivo:
            registros = json.load(arquivo)
            if not isinstance(registros, list):
                registros = []
    except (json.JSONDecodeError, IOError):
        registros = []

while True:
    print('>>>> Seja bem vindo(a) ao Calculo de FTY <<<<')

    try:  # O try protege contra entradas inválidas
        print('PASSO A PASSO 1...Responda o dia com >>> Segunda, Terça, Quarta, Quinta ou Sexta.')

        dia_d = input('Que dia é hoje: ').strip()
        if dia_d == '':
            print('Campo vazio, por favor digite o dia!')
            continue

        workday = input('Qual é seu workday: ').strip()
        if workday.isdigit() and len(workday) == 6:
            workday = int(workday)
        else:
            print('Digite o número do workday corretamente, ele deve conter 6 dígitos.')
            continue

        linha = input('Qual é a linha do backend deseja: ').strip().capitalize()
        if linha not in allowed_lines:
            print('Responda como no PASSO A PASSO 3.')
            continue

        Prime_fail = int(input(f'Digite o total prime fail da linha ({linha}): ').strip())
        Prime_Handle = int(input(f'Digite a estação do prime handle que foi mais utilizada, da linha ({linha}): ').strip())

        if Prime_Handle == 0:
            print('Prime Handle não pode ser zero.')
            continue

        firsttimeyield = (1 - (Prime_fail / Prime_Handle)) * 100
        print(f'O seu FTY é: {firsttimeyield:.2f}')

    except ValueError as erro:
        print('Erro de valor:', erro)
        continue

    registro = {
        'dia_d': dia_d,
        'workday': workday,
        'linha': linha,
        'Prime_fail': Prime_fail,
        'Prime_Handle': Prime_Handle,
        'firsttimeyield': firsttimeyield,
    }
    registros.append(registro)

    try:
        with open(caminho_completo, 'w', encoding='utf-8') as arquivo:
            json.dump(registros, arquivo, indent=4, ensure_ascii=False)
    except IOError as erro:
        print('Não foi possível salvar o arquivo:', erro)

    sair = input('Deseja sair? Responda sim ou não: ').strip().lower()
    if sair in ('sim',):
        print(f'Até mais, volte sempre!! Seus dados: {registros}')
        break
    elif sair in ('não', 'nao'):
        continue
    else:
        print('Resposta inválida. Voltando para o início.')
        continue
