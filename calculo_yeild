while True:
    print('>>>> Seja bem vindo(a) ao Calculo de Yeild <<<<')
    try: # utilizei o Try e o Except para que meu programa não quebre caso dê um erro, nesse caso de "ValueError"
        dia_d = float(input('que dia é hoje: ')) # aqui foi feito o input para a capitalização de dados para o calculo.
        jag = int(input('qual é seu jag: ')) # aqui foi feito o input para a capitalização de dados para o calculo.
        linha = (input('qual é a liha: ')) # aqui foi feito o input para a capitalização de dados para o calculo.
