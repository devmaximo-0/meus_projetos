import json

dicionario = {}
alnol = ['Be1', 'Be2', 'Be3', 'Be4', 'Be5', 'Be6', 'Be7', 'Be8', 'Be9', 'Be10', 'Be11', 'Be12', 'Be13', 'Be14', 'Be15', 'Be16'] # allowed number of lines
while True:
    print('>>>> Seja bem vindo(a) ao Calculo de FTY <<<<')

    try: # utilizei o Try e o Except para que meu programa não quebre caso dê um erro, nesse caso de "ValueError"
            print('PASSO A PASSO 1...Responda o dia com >>> Segunda, Terça, Quarta, Quinta ou Sexta.')

            dia_d = (input('Que dia é hoje: ')) # aqui foi feito o input para a capitalização de dados para o calculo.
            if dia_d == '':
                  print('campo vazio, por favor digite algo!!!')
                  continue
            workday = (input('Qual é seu workday: ')) # aqui foi feito o input para a capitalização de dados para o calculo.

            if workday.isdigit() and len(workday) == 6:  # converte para inteiro só depois da validação
                  workday = int(workday)

            else:
                  print('digite o número do workday corretamente, ele deve conter 6 digitos.')
                  continue

            
            linha = (input('Qual é a linha do backend deseja: ')).capitalize() # aqui foi feito o input para a capitalização de dados para o calculo.

            if linha not in alnol:
                print('Responda como no " PASSO A PASSO 3 "')
                continue
            Prime_fail = int(input(f'Digite o total prime fail da linha ({linha}): ')) # aqui foi feito o input para a capitalização de dados para o calculo.
            
            Prime_Handle = int(input(f'Digite a estação do prime handle que foi mais ultilizada, da linha ({linha}): ')) # aqui foi feito o input para a capitalização de dados para o calculo.
             
            if Prime_Handle == 0:
                    print("Prime Handle não pode ser zero.")
                    continue

            firsttimeyield =  (1- (Prime_fail / Prime_Handle)) * 100

            print(f'O seu FTY é: {firsttimeyield:.2f}')
                    
    except ValueError as erro:
            print('Erro de valor:', erro)
            continue


    sair = input('deseja sair ? responda sim ou não: ').lower()
    if sair =='não':
          continue
    elif sair == 'sim':
         dicionario.update({'dia_d': dia_d, 'workday': workday, 'linha': linha, 'Prime_fail': Prime_fail, 'Prime_Handle': Prime_Handle, 'firsttimeyield': firsttimeyield}) # o lista.update trasfere os resultados para um dicionario vázio chamado de dicionario.
         print(f'Até mais, volte sempre!! seus dados: {dicionario}')
         break 
    
